# ============================================================
# Grid Infrastructure Detection & Siting Pipeline — .gitignore
# ============================================================

# ── OS / Editor ──────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.vscode/
.idea/

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
*.egg
.eggs/
*.so

# ── Temporary / utility files ────────────────────────────────
direval.py
directory_tree.txt

# ── Model weights (download via scripts/download_assets.py) ─
model/ensemble_model.pt

# ── Demo data (extract via scripts/extract_region.py) ────────
demo_data/metadata.csv
demo_data/images/

# ── Runtime data (fetched via scripts/fetch_data.py) ─────────
data/buildings/
data/osm/
data/census/

# ── Pipeline output (generated at runtime) ───────────────────
# preloaded_demo_output/ is tracked as reference; fresh runs go to output/
output/

# ── Documents (submitted separately, not in repo) ───────────
technical_manual.docx
